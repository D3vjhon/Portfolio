---
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Demo de Fuentes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&family=Poppins:wght@400;600;700&family=Raleway:wght@400;600;700&family=Montserrat:wght@400;600;700&family=Playfair+Display:wght@400;600;700&family=Space+Grotesk:wght@400;600;700&family=Roboto:wght@400;600;700&family=DM+Sans:wght@400;600;700&family=Outfit:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background-color: #000;
        color: #fff;
        padding: 40px;
        min-height: 100vh;
      }

      h1 {
        text-align: center;
        margin-bottom: 50px;
        font-size: 32px;
      }

      .fonts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        gap: 40px;
        max-width: 1200px;
        margin: 0 auto;
      }

      .font-card {
        background-color: #1a1a1a;
        padding: 30px;
        border-radius: 8px;
        border: 1px solid #333;
      }

      .font-card h2 {
        font-size: 24px;
        margin-bottom: 20px;
        color: #aaa;
        font-weight: 600;
      }

      .font-preview {
        margin-bottom: 15px;
      }

      .preview-text {
        font-size: 20px;
        margin-bottom: 10px;
        line-height: 1.6;
      }

      .preview-code {
        font-size: 14px;
        color: #888;
      }

      /* Fuentes */
      .inter .preview-text {
        font-family: 'Inter', sans-serif;
      }

      .poppins .preview-text {
        font-family: 'Poppins', sans-serif;
      }

      .raleway .preview-text {
        font-family: 'Raleway', sans-serif;
      }

      .montserrat .preview-text {
        font-family: 'Montserrat', sans-serif;
      }

      .playfair .preview-text {
        font-family: 'Playfair Display', serif;
      }

      .space-grotesk .preview-text {
        font-family: 'Space Grotesk', sans-serif;
      }

      .roboto .preview-text {
        font-family: 'Roboto', sans-serif;
      }

      .dm-sans .preview-text {
        font-family: 'DM Sans', sans-serif;
      }

      .outfit .preview-text {
        font-family: 'Outfit', sans-serif;
      }
    </style>
  </head>
  <body>
    <h1>Demo de Fuentes para tu Portafolio</h1>

    <div class="fonts-grid">
      <div class="font-card inter">
        <h2>Inter</h2>
        <div class="font-preview">
          <div class="preview-text">Inter - Limpia y profesional</div>
          <div class="preview-code">font-family: 'Inter'</div>
        </div>
      </div>

      <div class="font-card poppins">
        <h2>Poppins</h2>
        <div class="font-preview">
          <div class="preview-text">Poppins - Moderna y amigable</div>
          <div class="preview-code">font-family: 'Poppins'</div>
        </div>
      </div>

      <div class="font-card raleway">
        <h2>Raleway</h2>
        <div class="font-preview">
          <div class="preview-text">Raleway - Elegante y sofisticada</div>
          <div class="preview-code">font-family: 'Raleway'</div>
        </div>
      </div>

      <div class="font-card montserrat">
        <h2>Montserrat</h2>
        <div class="font-preview">
          <div class="preview-text">Montserrat - Geométrica y moderna</div>
          <div class="preview-code">font-family: 'Montserrat'</div>
        </div>
      </div>

      <div class="font-card playfair">
        <h2>Playfair Display</h2>
        <div class="font-preview">
          <div class="preview-text">Playfair Display - Elegante premium</div>
          <div class="preview-code">font-family: 'Playfair Display'</div>
        </div>
      </div>

      <div class="font-card space-grotesk">
        <h2>Space Grotesk</h2>
        <div class="font-preview">
          <div class="preview-text">Space Grotesk - Tech y robusta</div>
          <div class="preview-code">font-family: 'Space Grotesk'</div>
        </div>
      </div>

      <div class="font-card roboto">
        <h2>Roboto</h2>
        <div class="font-preview">
          <div class="preview-text">Roboto - Clásica y versátil</div>
          <div class="preview-code">font-family: 'Roboto'</div>
        </div>
      </div>

      <div class="font-card dm-sans">
        <h2>DM Sans</h2>
        <div class="font-preview">
          <div class="preview-text">DM Sans - Moderna y geométrica</div>
          <div class="preview-code">font-family: 'DM Sans'</div>
        </div>
      </div>

      <div class="font-card outfit">
        <h2>Outfit</h2>
        <div class="font-preview">
          <div class="preview-text">Outfit - Futura y contemporánea</div>
          <div class="preview-code">font-family: 'Outfit'</div>
        </div>
      </div>
    </div>
  </body>
</html>
