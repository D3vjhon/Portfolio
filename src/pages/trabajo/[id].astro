---
import Layout from '../../layouts/Layout.astro';
import { jobs } from '../../data/jobs';

export async function getStaticPaths() {
  return jobs.map((job) => ({
    params: { id: job.id },
    props: { job },
  }));
}

const { job } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${job.role.es} — ${job.company.es} — D3vjh0n`} currentPage={base + '/trabajo'}>
  <article class="detail">
    <div class="detail-header">
      <a href={base + '/#trabajo'} class="detail-back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        Volver
      </a>
      <span class="detail-period">{job.period.es}</span>
    </div>

    <h1 class="detail-role">{job.role.es}</h1>
    <p class="detail-company">{job.company.es}</p>

    <div class="detail-media">
      {job.images
        ? <div class="carousel" data-carousel>
            <div class="carousel-track" data-track>
              {job.images.map((img, i) => (
                <div class="carousel-slide" data-slide={i}>
                  <img src={`/${img}`} alt={`${job.company.es} - ${i + 1}`} class="carousel-img" />
                </div>
              ))}
            </div>
            <div class="carousel-dots" data-dots>
              {job.images.map((_, i) => (
                <button class="carousel-dot" data-dot={i}></button>
              ))}
            </div>
          </div>
        : <div class="detail-img-main">
            {job.image
              ? <img src={`/${job.image}`} alt={job.company.es} class="detail-img" />
              : <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18"/><line x1="8" y1="2" x2="8" y2="22"/><line x1="16" y1="2" x2="16" y2="22"/><line x1="2" y1="8" x2="22" y2="8"/><line x1="2" y1="16" x2="22" y2="16"/></svg>
            }
          </div>
      }
    </div>

    <div class="detail-description">
      <p>{job.description.es}</p>
    </div>

    <div class="detail-highlights">
      <h2>Logros destacados</h2>
      <ul>
        {job.details.es.map((d) => (
          <li>{d}</li>
        ))}
      </ul>
    </div>

    <div class="detail-tech">
      <h2>Tecnologías</h2>
      <div class="detail-tags">
        {job.tech.map((t) => (
          <span class="tag">{t}</span>
        ))}
      </div>
    </div>
  </article>

  <style>
    .detail {
      max-width: 720px;
    }

    .detail-header {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 24px;
    }

    .detail-back {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: var(--text-secondary);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: color 0.2s;
    }

    .detail-back:hover {
      color: var(--accent);
    }

    .detail-back svg {
      width: 16px;
      height: 16px;
    }

    .detail-period {
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
    }

    .detail-role {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 4px;
    }

    .detail-company {
      font-size: 17px;
      color: var(--text-secondary);
      margin-bottom: 28px;
    }

    .detail-media {
      margin-bottom: 28px;
    }

    .detail-img-main {
      width: 100%;
      height: 240px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .detail-img-main svg {
      width: 72px;
      height: 72px;
      color: var(--text-muted);
      opacity: 0.3;
    }
    .detail-img {
      width: 100%; height: 100%;
      object-fit: contain; padding: 16px;
    }

    .detail-description {
      font-size: 16px;
      line-height: 1.7;
      color: var(--text-secondary);
      margin-bottom: 32px;
    }

    .detail-highlights {
      margin-bottom: 32px;
    }

    .detail-highlights h2 {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 14px;
    }

    .detail-highlights ul {
      list-style: none;
      padding: 0;
    }

    .detail-highlights li {
      position: relative;
      padding-left: 20px;
      margin-bottom: 10px;
      font-size: 15px;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    .detail-highlights li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 8px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--accent);
      opacity: 0.6;
    }

    .detail-tech h2 {
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 14px;
    }

    .detail-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag {
      font-size: 13px;
      font-weight: 500;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 4px 12px;
      border-radius: 10px;
    }

    .carousel { position: relative; width: 100%; }
    .carousel-track {
      display: flex; overflow: hidden;
      border-radius: 10px; border: 1px solid var(--border);
      background: var(--card-bg);
    }
    .carousel-slide {
      flex: 0 0 100%; display: none;
      height: 300px; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .carousel-slide.active { display: flex; }
    .carousel-img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .carousel-dots {
      display: flex; justify-content: center; gap: 8px;
      margin-top: 12px;
    }
    .carousel-dot {
      width: 10px; height: 10px; border-radius: 50%;
      border: 2px solid var(--accent); background: transparent;
      cursor: pointer; padding: 0; transition: all .2s;
    }
    .carousel-dot.active { background: var(--accent); }
  </style>

  <script>
    function initCarousel(){
      var carousel = document.querySelector('[data-carousel]');
      if(!carousel) return;
      var slides = carousel.querySelectorAll('[data-slide]');
      var dots = carousel.querySelectorAll('[data-dot]');
      var current = 0;
      if(slides.length) {
        slides[0].classList.add('active');
        if(dots.length) dots[0].classList.add('active');
      }
      dots.forEach(function(dot, i) {
        dot.addEventListener('click', function() {
          slides[current].classList.remove('active');
          dots[current].classList.remove('active');
          current = i;
          slides[current].classList.add('active');
          dots[current].classList.add('active');
        });
      });
    }
    document.addEventListener('astro:after-swap', initCarousel);
    initCarousel();
  </script>
</Layout>
