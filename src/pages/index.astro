  { name: { es:'Frontend', en:'Frontend', pt:'Frontend' }, i18n:'skills.category.frontend', skills:['HTML5','CSS3','JavaScript','React','Astro','Tailwind','shadcn','Formik','Yup'], icons:['html','css','js','react','astro','tailwind','shadcn','formik','yup'] },
  { name: { es:'Backend', en:'Backend', pt:'Backend' }, i18n:'skills.category.backend', skills:['Node.js','Python','PostgreSQL','MongoDB','Supabase','Express.js','Django REST'], icons:['node','python','db','db','supabase','express','django'] },
