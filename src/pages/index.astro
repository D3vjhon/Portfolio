  <style>
    .hero-section {
      min-height: calc(100vh - 72px);
      display: flex;
      align-items: center;
      padding: 0;
      margin-bottom: 80px;
    }

    .hero-content {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      gap: 60px;
    }

    .hero-text { flex: 1; max-width: 580px; }

    .hero-badge {
      display: inline-block;
      font-size: 12px;
      color: #fff;
      background: linear-gradient(135deg, var(--accent), #B45309);
      border: none;
      padding: 6px 16px;
      border-radius: 20px;
      margin-bottom: 20px;
      width: fit-content;
      font-weight: 700;
      letter-spacing: 0.5px;
      box-shadow: 0 0 20px var(--accent-glow);
      animation: badgePulse 2s ease-in-out infinite;
      position: relative;
    }

    @keyframes badgePulse {
      0%, 100% { transform: scale(1); box-shadow: 0 0 20px var(--accent-glow); }
      50% { transform: scale(1.04); box-shadow: 0 0 35px var(--accent-glow), 0 0 60px rgba(217,119,6,0.15); }
    }

    .greeting {
      display: block;
      font-size: 18px;
      font-weight: 500;
      color: var(--text-secondary);
      margin-bottom: 6px;
    }

    .hero-name {
      font-size: 56px;
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: 10px;
      letter-spacing: -1px;
    }

    .hero-title {
      font-size: 20px;
      font-weight: 600;
      color: var(--accent);
      margin-bottom: 16px;
    }

    .hero-tagline {
      font-size: 16px;
      color: var(--text-secondary);
      line-height: 1.7;
      margin-bottom: 28px;
      max-width: 480px;
    }

    .hero-links { display: flex; align-items: center; gap: 14px; }

    .btn-icon {
      width: 42px; height: 42px; border-radius: 10px;
      border: 1px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      color: var(--text-secondary); transition: all .2s;
    }
    .btn-icon:hover {
      color: var(--accent); border-color: var(--accent);
      background: var(--accent-dim); box-shadow: 0 0 20px var(--accent-glow);
    }
    .btn-icon svg { width: 18px; height: 18px; }

    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 9px 22px; border-radius: 8px;
      border: 1px solid var(--accent); color: var(--accent);
      text-decoration: none; font-weight: 600; font-size: 14px;
      transition: all .2s; white-space: nowrap;
    }
    .btn-outline:hover {
      background: var(--accent); color: #fff;
      box-shadow: 0 0 24px var(--accent-glow);
    }

    .hero-avatar { position: relative; flex-shrink: 0; }

    .avatar-frame {
      width: 200px; height: 200px; border-radius: 50%;
      border: 3px solid var(--accent);
      display: flex; align-items: center; justify-content: center;
      background: var(--card-bg); position: relative; z-index: 1;
      overflow: hidden;
    }
    .avatar-icon { width: 80px; height: 80px; color: var(--text-muted); opacity: .4; }

    .avatar-glow {
      position: absolute; top: -10px; left: -10px; right: -10px; bottom: -10px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--accent-glow), transparent 70%);
      animation: pulse 3s ease-in-out infinite;
    }

    @keyframes pulse {
      0%,100%{opacity:.5;transform:scale(1)}
      50%{opacity:1;transform:scale(1.05)}
    }

    .section { padding: 60px 0; }

    .section + .section { border-top: 1px solid var(--border); }

    .section-title {
      font-size: 28px; font-weight: 700; margin-bottom: 6px;
      display: flex; align-items: center; gap: 10px;
    }
    .section-icon { width: 24px; height: 24px; flex-shrink: 0; }

    .section-desc {
      color: var(--text-secondary); font-size: 15px; margin-bottom: 28px;
    }

    /* ── Skills ── */
    .skill-category {
      margin-bottom: 24px;
    }

    .category-title {
      font-size: 16px; font-weight: 600; margin-bottom: 16px;
      color: var(--text); padding-left: 10px;
      border-left: 3px solid var(--accent);
    }

    .skill-cards {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
      gap: 8px;
    }

    .skill-card {
      display: flex; flex-direction: column; align-items: center;
      gap: 5px; padding: 12px 8px;
      background: var(--bg); border: 1px solid var(--border);
      border-radius: 8px; transition: all .2s;
    }
    .skill-card:hover {
      border-color: var(--accent); background: var(--accent-dim);
      transform: translateY(-2px);
    }

    .skill-icon { width: 16px; height: 16px; }
    .skill-icon svg { width: 16px; height: 16px; }

    .skill-name {
      font-size: 11px; font-weight: 500; color: var(--text-secondary);
      text-align: center;
    }
    .skill-card:hover .skill-name { color: var(--text); }

    /* ── Timeline ── */
    .next-card-text { text-align: center; padding: 20px 0; }
    .timeline-role-next {
      font-size: 22px; font-weight: 700; margin-bottom: 6px;
      color: var(--accent);
    }
    .timeline-desc-next {
      font-size: 14px; color: var(--text-secondary); line-height: 1.6;
    }
    .timeline-dot-next {
      background: var(--accent-dim); border-color: var(--accent);
      box-shadow: 0 0 0 2px var(--accent), 0 0 20px var(--accent-glow);
      animation: dotPulse 2s ease-in-out infinite;
    }
    @keyframes dotPulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.3); }
    }
    .timeline-card-next {
      background: var(--accent-dim); border: 1px dashed var(--accent);
      cursor: default;
    }
    .timeline-card-next:hover { transform: none; border-color: var(--accent); }
    .timeline-img-next {
      border-color: var(--accent); background: transparent;
    }
    .timeline-img-next svg { color: var(--accent); opacity: .6; }
    .clock-anim { transform-origin: 12px 12px; }
    .clock-hour {
      transform-origin: 12px 12px;
      animation: spinHour 12s linear infinite;
    }
    .clock-minute {
      transform-origin: 12px 12px;
      animation: spinMinute 1s linear infinite;
    }
    @keyframes spinHour { to { transform: rotate(360deg); } }
    @keyframes spinMinute { to { transform: rotate(360deg); } }
    .timeline-period-next { font-size: 11px; color: var(--accent); font-weight: 600; }

    .timeline { position: relative; padding-left: 24px; }

    .timeline-line {
      position: absolute; left: 9px; top: 0; bottom: 0;
      width: 2px; background: var(--border);
    }

    .timeline-item { position: relative; margin-bottom: 20px; }
    .timeline-item:last-child { margin-bottom: 0; }

    .timeline-dot {
      position: absolute; left: -17px; top: 18px;
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); border: 2px solid var(--bg);
      box-shadow: 0 0 0 2px var(--accent); z-index: 1;
    }

    .timeline-card {
      display: block; background: var(--card-bg);
      border: 1px solid var(--border); border-radius: 8px;
      padding: 16px; transition: all .2s;
      text-decoration: none; color: inherit;
    }
    .timeline-card:hover {
      border-color: var(--accent); transform: translateX(3px);
    }

    .timeline-card-content { display: flex; gap: 12px; }
    .timeline-card-main { flex: 1; }
    .timeline-card-media { flex-shrink: 0; }

    .timeline-img-placeholder {
      width: 68px; height: 68px; border-radius: 50%;
      border: 2px solid var(--accent); background: var(--bg);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .timeline-img-placeholder svg { width: 28px; height: 28px; opacity: .35; }
    .timeline-img { width: 100%; height: 100%; object-fit: cover; }

    .timeline-period {
      display: inline-block; font-size: 11px; font-weight: 600;
      color: var(--accent); margin-bottom: 4px; letter-spacing: .3px;
    }

    .timeline-role { font-size: 16px; font-weight: 600; margin-bottom: 2px; }

    .timeline-company {
      font-size: 13px; color: var(--text-secondary); margin-bottom: 6px;
    }

    .timeline-desc {
      font-size: 12px; color: var(--text-secondary); line-height: 1.5;
    }

    .timeline-tech {
      display: flex; flex-wrap: wrap; gap: 4px; margin-top: 10px;
    }

    .tech-tag {
      font-size: 10px; font-weight: 500; color: var(--accent);
      background: var(--accent-dim); padding: 2px 7px; border-radius: 8px;
    }

    /* ── Contact ── */
    .contact-info {
      display: flex; flex-wrap: wrap; gap: 20px 32px;
    }

    .contact-item {
      display: flex; align-items: center; gap: 10px;
      color: var(--text-secondary); font-size: 14px;
      transition: color .2s;
    }
    .contact-item:hover { color: var(--accent); }
    .contact-item svg {
      width: 18px; height: 18px; flex-shrink: 0;
      color: var(--accent);
    }

    @media(max-width:768px){
      .hero-content{flex-direction:column;gap:40px}
      .hero-text{max-width:100%}
      .hero-name{font-size:32px}
      .hero-title{font-size:17px}
      .hero-tagline{font-size:14px}
      .avatar-frame{width:140px;height:140px}
      .avatar-icon{width:56px;height:56px}
      .section{padding:40px 0}
      .skill-cards{grid-template-columns:repeat(auto-fill,minmax(70px,1fr))}
      .timeline-img-placeholder{width:56px;height:56px}
    }
  </style>
</Layout>
