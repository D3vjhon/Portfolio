---

<Layout title="D3vjh0n — Full Stack Developer" currentPage={base}>
  <!-- ─── HERO ─── -->
  <section class="hero-section">
    <div class="hero-content">
      <div class="hero-text">
        <span class="hero-badge" data-i18n="hero.badge">🚀 Disponible para proyectos</span>
        <h1 class="hero-name">
          <span class="greeting" data-i18n="hero.greeting">Hola, soy</span>
          D3vjh0n
        </h1>
        <p class="hero-title" data-i18n="hero.title">Full Stack Developer</p>
        <p class="hero-tagline" data-i18n="hero.tagline">
          Construyo aplicaciones web modernas con foco en rendimiento, diseño limpio y buena experiencia de usuario.
        </p>
        <div class="hero-links">
          <a href="https://github.com/D3vjhon" target="_blank" class="btn-icon" rel="noopener noreferrer" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/jhon-cambara-a7205b304/" target="_blank" class="btn-icon" rel="noopener noreferrer" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={base + '/cv.pdf'} class="btn-outline" download>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            <span>Descargar CV</span>
          </a>
        </div>
      </div>
      <div class="hero-avatar">
        <div class="avatar-frame">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="avatar-icon"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </div>
        <div class="avatar-glow"></div>
      </div>
    </div>
  </section>

  <!-- ─── TRABAJO ─── -->
  <section class="section reveal" id="trabajo">
    <h2 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg> <span data-i18n="trabajo.title">Experiencia</span></h2>
    <p class="section-desc" data-i18n="trabajo.desc">Mi trayectoria profesional hasta ahora.</p>

    <div class="timeline">
      <div class="timeline-line"></div>
      {jobs.map((job) => (
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <a href={base + '/trabajo/' + job.id} class="timeline-card">
            <span class="timeline-period">{job.period.es}</span>
            <div class="timeline-card-content">
              <div class="timeline-card-main">
                <h3 class="timeline-role">{job.role.es}</h3>
                <p class="timeline-company">{job.company.es}</p>
                <p class="timeline-desc">{job.description.es}</p>
              </div>
              <div class="timeline-card-media">
                <div class="timeline-img-placeholder">
                  {job.image
                    ? <img src={base + '/' + job.image} alt={job.company.es} class="timeline-img" />
                    : <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="2.18"/><line x1="8" y1="2" x2="8" y2="22"/><line x1="16" y1="2" x2="16" y2="22"/><line x1="2" y1="8" x2="22" y2="8"/><line x1="2" y1="16" x2="22" y2="16"/></svg>
                  }
                </div>
              </div>
            </div>
            <div class="timeline-tech">
              {job.tech.map((t) => (<span class="tech-tag">{t}</span>))}
            </div>
          </a>
        </div>
      ))}
      <div class="timeline-item">
        <div class="timeline-dot timeline-dot-next"></div>
        <div class="timeline-card timeline-card-next">
          <div class="timeline-card-content">
            <div class="timeline-card-main next-card-text">
              <span class="timeline-period timeline-period-next">Próximo</span>
              <h3 class="timeline-role-next">¿El próximo eres tú?</h3>
              <p class="timeline-desc-next">Esta línea de tiempo aún tiene espacio. Si tienes un proyecto en mente, hablemos y podemos llenarla juntos.</p>
            </div>
            <div class="timeline-card-media">
              <div class="timeline-img-placeholder timeline-img-next">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="clock-anim">
                  <circle cx="12" cy="12" r="10"/>
                  <line x1="12" y1="12" x2="12" y2="7" stroke-width="2" stroke-linecap="round" class="clock-hour"/>
                  <line x1="12" y1="12" x2="16" y2="12" stroke-width="1.5" stroke-linecap="round" class="clock-minute"/>
                  <circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SKILLS ─── -->
  <section class="section reveal" id="skills">
    <h2 class="section-title"><svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg> <span data-i18n="skills.title">Skills</span></h2>
    <p class="section-desc" data-i18n="skills.desc">Tecnologías y herramientas con las que trabajo.</p>

    <div class="skills-grid">
      {skillCategories.map((cat) => (
        <div class="skill-category reveal">
          <h3 class="category-title" data-i18n={cat.i18n}>{cat.name.es}</h3>
          <div class="skill-cards stagger">
            {cat.skills.map((skill, idx) => (
              <div class="skill-card">
                <span class="skill-icon"><Fragment set:html={skillIcons[cat.icons[idx]]} /></span>
                <span class="skill-name">{skill}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── CONTACTO ─── -->
  <section class="section contact reveal" id="contacto">
