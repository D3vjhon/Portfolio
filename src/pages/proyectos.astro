---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
const projects = [
  {
    title: "CrudRedux",
    desc: {
      es: "CRM liviano con React 18 + Redux Toolkit + TypeScript. CRUD completo de clientes y proyectos con búsqueda, paginación, persistencia local y UI con Chakra UI v3.",
      en: "Lightweight CRM built with React 18 + Redux Toolkit + TypeScript. Full CRUD for clients and projects with search, pagination, local persistence and Chakra UI v3.",
      pt: "CRM leve com React 18 + Redux Toolkit + TypeScript. CRUD completo de clientes e projetos com busca, paginação, persistência local e UI com Chakra UI v3."
    },
    stack: ["React", "Redux Toolkit", "TypeScript", "Chakra UI", "Vite"],
    demo: "https://crud-redux-phi.vercel.app",
    github: "https://github.com/D3vjhon/CrudRedux",
    color: "#D97706",
    img: null
  },
  {
    title: "YourMessage",
    desc: {
      es: "Plataforma de mensajería empresarial tipo Slack/Teams. Multi-workspace con canales públicos/privados, mensajería en tiempo real, indicadores de escritura, presencia online, búsqueda global y panel de administración.",
      en: "Enterprise messaging platform like Slack/Teams. Multi-workspace with public/private channels, real-time messaging, typing indicators, online presence, global search and admin panel.",
      pt: "Plataforma de mensagens empresarial tipo Slack/Teams. Multi-workspace com canais públicos/privados, mensagens em tempo real, indicadores de digitação, presença online, pesquisa global e painel de administração."
    },
    stack: ["Next.js", "Supabase", "TypeScript", "Tailwind CSS", "Vercel"],
    demo: "https://your-message-six.vercel.app",
    github: null,
    color: "#2563EB",
    img: null
  }
];
---
<Layout title="Proyectos — D3vjh0n" currentPage={base + '/proyectos'}>
  <section class="page-header reveal">
    <h1 class="page-title"><svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="section-icon"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg> <span data-i18n="proyectos.title">Proyectos</span></h1>
    <p class="page-desc" data-i18n="proyectos.desc">Algunos trabajos personales y profesionales que he realizado.</p>
  </section>

  <div class="projects-grid stagger">
    {projects.map((project) => (
      <article class="project-card">
        <div class="project-image" style={`background: linear-gradient(135deg, ${project.color}18, var(--bg));`}>
          {project.img ? (
            <img src={project.img} alt={project.title} class="project-img" />
          ) : (
            <div class="project-img-placeholder">
              <svg viewBox="0 0 24 24" fill="none" stroke={project.color} stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                <line x1="8" y1="21" x2="16" y2="21"/>
                <line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
          )}
        </div>
        <div class="project-body">
          <h2 class="project-title">{project.title}</h2>
          <p class="project-desc">{project.desc.es}</p>
          <div class="project-stack">
            {project.stack.map((tech) => (
              <span class="project-tag">{tech}</span>
            ))}
          </div>
          <div class="project-links">
            <a href={project.demo} class="project-link primary" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              <span data-i18n="project.demo">Demo</span>
            </a>
            {project.github && (
            <a href={project.github} class="project-link" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              <span data-i18n="project.code">Código</span>
            </a>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>

  <style>
    .page-header {
      margin-bottom: 40px;
    }

    .page-title {
      font-size: 32px;
      font-weight: 700;
      margin-bottom: 6px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .page-title svg { width: 28px; height: 28px; flex-shrink: 0; }

    .page-desc {
      color: var(--text-secondary);
      font-size: 15px;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 20px;
    }

    .project-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      transition: all 0.2s;
      display: flex;
      flex-direction: column;
    }

    .project-card:hover {
      border-color: var(--accent);
      transform: translateY(-3px);
    }

    .project-image {
      height: 180px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .project-img-placeholder svg {
      width: 56px;
      height: 56px;
      opacity: 0.5;
    }

    .project-body {
      padding: 18px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .project-desc { flex: 1; }

    .project-img { width:100%; height:100%; object-fit:cover; display:block; }

    .project-title {
      font-size: 17px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .project-desc {
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin-bottom: 14px;
    }

    .project-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-bottom: 14px;
    }

    .project-tag {
      font-size: 11px;
      font-weight: 500;
      color: var(--accent);
      background: var(--accent-dim);
      padding: 3px 9px;
      border-radius: 10px;
    }

    .project-links {
      display: flex;
      gap: 8px;
      margin-top: auto;
    }

    .project-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      color: var(--text-secondary);
      transition: all 0.2s;
      padding: 7px 14px;
      border-radius: 6px;
      border: 1px solid var(--border);
      flex: 1;
    }

    .project-link svg {
      width: 15px;
      height: 15px;
      flex-shrink: 0;
    }

    .project-link:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--accent-dim);
    }

    .project-link.primary {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    .project-link.primary:hover {
      background: #C25F00;
      border-color: #C25F00;
      color: #fff;
    }

    @media (max-width: 768px) {
      .page-title { font-size: 26px; }
      .projects-grid { grid-template-columns: 1fr; }
      .project-image { height: 140px; }
    }
  </style>
</Layout>
