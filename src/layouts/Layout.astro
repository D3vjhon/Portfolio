---
import { ViewTransitions } from 'astro:transitions';
import { languages } from '../i18n/translations';

interface Props {
  title: string;
  currentPage: string;
}

const { title, currentPage } = Astro.props;
const navIcons = {
  inicio: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>',
  proyectos: '<svg viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6a2 2 0 0 1 2-2h5l2 2h9a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6z"/></svg>'
};

const menuItems = [
  { name: "Inicio", href: "/", i18n: "nav.inicio", icon: navIcons.inicio },
  { name: "Proyectos", href: "/proyectos", i18n: "nav.proyectos", icon: navIcons.proyectos }
];
---

<!doctype html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function(){
        var t=localStorage.getItem('theme');if(t)document.documentElement.dataset.theme=t;
        var l=localStorage.getItem('lang');if(l)document.documentElement.lang=l;
      })();
    </script>
    <style is:global>
      :root {
        --accent: #D97706;
        --accent-dim: rgba(217,119,6,0.12);
        --accent-glow: rgba(217,119,6,0.25);
        --font-display: 'Press Start 2P',monospace;
        --font-body: 'Space Grotesk',sans-serif;
      }
      html[data-theme="dark"] {
        --bg:#0a0a0a; --bg-rgb:10,10,10; --bg-surface:#141414; --text:#f5f5f5; --text-secondary:#a0a0a0;
        --text-muted:#555; --border:#222; --card-bg:#141414; --input-bg:#1a1a1a;
      }
      html[data-theme="light"] {
        --bg:#f8f6f2; --bg-rgb:248,246,242; --bg-surface:#ffffff; --text:#1a1a1a; --text-secondary:#666;
        --text-muted:#999; --border:#e0ddd8; --card-bg:#ffffff; --input-bg:#f0eee8;
      }
      *{margin:0;padding:0;box-sizing:border-box}
      body{
        background:var(--bg);color:var(--text);font-family:var(--font-body);
        min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s;
      }
      ::selection{background:var(--accent);color:#fff}
      ::-webkit-scrollbar{width:6px}
      ::-webkit-scrollbar-track{background:var(--bg)}
      ::-webkit-scrollbar-thumb{background:var(--text-muted);border-radius:3px}

      #particle-canvas{
        position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;
      }

      .top-bar{
        position:sticky;top:0;z-index:20;
        display:flex;align-items:center;justify-content:space-between;
        padding:12px 48px;height:72px;gap:12px;
        background:var(--bg);
        transition:background .3s,backdrop-filter .3s;
      }
      .top-bar.scrolled{
        background:rgba(var(--bg-rgb),0.75);
        backdrop-filter:blur(12px);
        -webkit-backdrop-filter:blur(12px);
      }

      .top-bar-left{display:flex;align-items:center;gap:12px}
      .top-bar-right{display:flex;align-items:center;gap:16px}
   

      .top-logo{
        font-family:var(--font-display);font-size:14px;color:var(--text);
        letter-spacing:1px;text-decoration:none;
      }
      .top-logo::after{content:'</>';color:var(--accent);margin-left:6px;font-size:12px;font-weight:700}

      .nav-link{
        display:inline-flex;align-items:center;gap:6px;
        text-decoration:none;color:var(--text-secondary);font-size:13px;font-weight:500;
        padding:8px 16px;border-radius:8px;transition:all .2s;
      }
      .nav-link:hover{color:var(--text);background:var(--accent-dim)}
      .nav-link.active{color:var(--accent)}
      .nav-link svg{width:16px;height:16px}

      .top-btn{
        background:none;border:none;color:var(--text-secondary);
        padding:6px 8px;border-radius:6px;cursor:pointer;font-size:14px;
        display:flex;align-items:center;gap:6px;transition:all .2s;font-weight:500;
        font-family:var(--font-body);line-height:1;
      }
      .top-btn:hover{color:var(--accent)}
      .top-btn svg{width:16px;height:16px}

      .lang-wrapper{position:relative}
      .lang-options{
        display:none;position:absolute;top:calc(100% + 4px);right:0;
        background:var(--bg-surface);border:1px solid var(--border);border-radius:6px;
        min-width:160px;overflow:hidden;z-index:30;
      }
      .lang-options.open{display:block}
      .lang-opt{
        display:flex;align-items:center;gap:8px;width:100%;
        padding:8px 12px;border:none;background:none;color:var(--text-secondary);
        font-family:var(--font-body);font-size:13px;cursor:pointer;transition:all .1s;
        text-align:left;
      }
      .lang-opt:hover{background:var(--accent-dim);color:var(--text)}
      .lang-opt.active{color:var(--accent);background:var(--accent-dim)}
      .lang-opt .flag{font-size:18px;line-height:1}

      .content{
        position:relative;z-index:1;
        max-width:1100px;margin:0 auto;padding:48px 32px;
      }

      /* ── Animations ── */
      @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
      @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }
      @keyframes scaleIn { from { opacity:0; transform:scale(0.9); } to { opacity:1; transform:scale(1); } }

      html { scroll-behavior: smooth; }

      .reveal { opacity:0; transform:translateY(24px); transition:opacity .6s cubic-bezier(.22,1,.36,1), transform .6s cubic-bezier(.22,1,.36,1); }
      .reveal.visible { opacity:1; transform:translateY(0); }

      .reveal-left { opacity:0; transform:translateX(-30px); transition:opacity .5s cubic-bezier(.22,1,.36,1), transform .5s cubic-bezier(.22,1,.36,1); }
      .reveal-left.visible { opacity:1; transform:translateX(0); }

      .stagger > * { opacity:0; transform:translateY(16px); transition:opacity .5s cubic-bezier(.22,1,.36,1), transform .5s cubic-bezier(.22,1,.36,1); }
      .stagger.visible > *:nth-child(1) { transition-delay:0s; }
      .stagger.visible > *:nth-child(2) { transition-delay:.06s; }
      .stagger.visible > *:nth-child(3) { transition-delay:.12s; }
      .stagger.visible > *:nth-child(4) { transition-delay:.18s; }
      .stagger.visible > *:nth-child(5) { transition-delay:.24s; }
      .stagger.visible > *:nth-child(6) { transition-delay:.30s; }
      .stagger.visible > *:nth-child(7) { transition-delay:.36s; }
      .stagger.visible > *:nth-child(8) { transition-delay:.42s; }
      .stagger.visible > *:nth-child(9) { transition-delay:.48s; }
      .stagger.visible > *:nth-child(10) { transition-delay:.54s; }
      .stagger.visible > * { opacity:1; transform:translateY(0); }

      .hero-section .hero-text > * { animation:fadeUp .6s cubic-bezier(.22,1,.36,1) both; }
      .hero-section .hero-text > *:nth-child(1) { animation-delay:.1s; }
      .hero-section .hero-text > *:nth-child(2) { animation-delay:.2s; }
      .hero-section .hero-text > *:nth-child(3) { animation-delay:.3s; }
      .hero-section .hero-text > *:nth-child(4) { animation-delay:.4s; }
      .hero-section .hero-text > *:nth-child(5) { animation-delay:.5s; }
      .hero-section .hero-avatar { animation:scaleIn .6s cubic-bezier(.22,1,.36,1) .3s both; }

      /* ViewTransition */
      ::view-transition-old(root) { animation:fadeOut .25s ease both; }
      ::view-transition-new(root) { animation:fadeIn .35s ease .15s both; }
      @keyframes fadeOut { to { opacity:0; } }

      .btn-outline, .project-link, .timeline-card { transition:all .25s cubic-bezier(.22,1,.36,1); }
      .btn-outline:hover { transform:translateY(-2px); box-shadow:0 6px 20px var(--accent-glow); }
      .project-card:hover { transform:translateY(-4px); box-shadow:0 8px 30px rgba(0,0,0,.15); }

      @media(max-width:768px){
        .top-bar{padding:0 12px;height:auto;flex-wrap:wrap;gap:6px;padding:8px 12px}
        .top-bar-left{flex-wrap:wrap;gap:2px;order:1}
        .top-bar-right{order:2}
        .nav-link{font-size:13px;padding:6px 10px}
        .content{padding:20px 16px}
      }
    </style>
  </head>
  <body>
    <canvas id="particle-canvas" data-astro-persist></canvas>

    <div class="top-bar">
      <div class="top-bar-left">
        <a href="/" class="top-logo">D3vjh0n</a>
      </div>
      <div class="top-bar-right">
        <div class="lang-wrapper">
          <button class="top-btn lang-trigger" id="lang-trigger">
            <span id="lang-flag">🇪🇸</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="lang-options" id="lang-options">
            <button class="lang-opt" data-lang="es"><span class="flag">🇪🇸</span> Español</button>
            <button class="lang-opt" data-lang="en"><span class="flag">🇺🇸</span> English</button>
            <button class="lang-opt" data-lang="pt"><span class="flag">🇧🇷</span> Português</button>
          </div>
        </div>
        {menuItems.map((item)=>(
          <a href={item.href} class={`nav-link ${currentPage===item.href?'active':''}`} data-i18n={item.i18n}>
            <Fragment set:html={item.icon} />
            <span>{item.name}</span>
          </a>
        ))}
        <button class="top-btn" id="theme-toggle">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
      </div>
    </div>

    <main class="content">
      <slot />
    </main>

    <script>
      import { translations } from '../i18n/translations';

      // ── Particle Network ──
      var canvas, ctx, particles = [], animId;
      var COUNT = 120, MAX_DIST = 150;

      function resizeCanvas(){
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      function particleColor(alpha){
        var style = getComputedStyle(document.documentElement);
        var isDark = document.documentElement.dataset.theme === 'dark';
        if(isDark){
          var c = style.getPropertyValue('--accent').trim();
          return 'rgba(' + parseInt(c.slice(1,3),16) + ',' + parseInt(c.slice(3,5),16) + ',' + parseInt(c.slice(5,7),16) + ',' + alpha + ')';
        }
        return 'rgba(180,180,180,' + alpha + ')';
      }

      function lineColor(alpha){
        var isDark = document.documentElement.dataset.theme === 'dark';
        if(isDark){
          var style = getComputedStyle(document.documentElement);
          var c = style.getPropertyValue('--accent').trim();
          return 'rgba(' + parseInt(c.slice(1,3),16) + ',' + parseInt(c.slice(3,5),16) + ',' + parseInt(c.slice(5,7),16) + ',' + (alpha * 0.30) + ')';
        }
        return 'rgba(180,180,180,' + (alpha * 0.25) + ')';
      }

      function Particle(){
        this.x = Math.random() * canvas.width;
        this.y = Math.random() * canvas.height;
        this.vx = (Math.random() - 0.5) * 1.8;
        this.vy = (Math.random() - 0.5) * 1.8;
        this.r = Math.random() * 1.5 + 0.5;
      }
      Particle.prototype.update = function(){
        this.x += this.vx; this.y += this.vy;
        if(this.x < 0 || this.x > canvas.width) this.vx *= -1;
        if(this.y < 0 || this.y > canvas.height) this.vy *= -1;
      };

      function initParticles(){
        particles = [];
        for(var i=0;i<COUNT;i++) particles.push(new Particle());
      }

      function drawParticles(){
        ctx.clearRect(0,0,canvas.width,canvas.height);
        var pFill = particleColor(0.50);
        var p, dx, dy, dist, alpha, i, j;

        for(i=0;i<COUNT;i++){
          p = particles[i];
          p.update();
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.r, 0, Math.PI*2);
          ctx.fillStyle = pFill;
          ctx.fill();
        }

        for(i=0;i<COUNT;i++){
          for(j=i+1;j<COUNT;j++){
            dx = particles[i].x - particles[j].x;
            dy = particles[i].y - particles[j].y;
            dist = Math.sqrt(dx*dx + dy*dy);
            if(dist < MAX_DIST){
              alpha = 1 - dist / MAX_DIST;
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = lineColor(alpha);
              ctx.lineWidth = alpha * 1.5;
              ctx.stroke();
            }
          }
        }

        animId = requestAnimationFrame(drawParticles);
      }

      function startParticles(){
        canvas = document.getElementById('particle-canvas');
        if(!canvas) return;
        ctx = canvas.getContext('2d');
        resizeCanvas();
        initParticles();
        if(animId) cancelAnimationFrame(animId);
        drawParticles();
      }

      window.addEventListener('resize', function(){
        resizeCanvas();
      });

      // ── Theme ──
      function applyTheme(){
        var t = localStorage.getItem('theme') || 'dark';
        document.documentElement.dataset.theme = t;
      }

      document.addEventListener('click', function(e){
        var btn = e.target.closest('#theme-toggle');
        if(!btn) return;
        var next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        applyTheme();
      });

      // ── Language ──
      function getLang(){ return localStorage.getItem('lang') || 'es'; }

      function applyLang(){
        var lang = getLang();
        document.documentElement.lang = lang;

        var flag = document.getElementById('lang-flag');
        var map = {es:'🇪🇸',en:'🇺🇸',pt:'🇧🇷'};
        if(flag) flag.textContent = map[lang] || '🇪🇸';

        var opts = document.querySelectorAll('.lang-opt');
        opts.forEach(function(b){ b.classList.toggle('active', b.dataset.lang===lang); });

        document.getElementById('lang-options').classList.remove('open');

        var els = document.querySelectorAll('[data-i18n]');
        els.forEach(function(el){
          var key = el.dataset.i18n;
          if(translations[lang] && translations[lang][key]){
            if(el.tagName==='INPUT'||el.tagName==='TEXTAREA') el.placeholder = translations[lang][key];
            else el.textContent = translations[lang][key];
          }
        });

        applyTheme();
      }

      document.addEventListener('click', function(e){
        var t = e.target.closest('.lang-trigger');
        if(t){ document.getElementById('lang-options').classList.toggle('open'); return; }
        var o = e.target.closest('.lang-opt');
        if(o){
          var l = o.dataset.lang;
          if(l !== getLang()){ localStorage.setItem('lang', l); applyLang(); }
          return;
        }
        if(!e.target.closest('.lang-wrapper')) document.getElementById('lang-options').classList.remove('open');
      });

      // ── Scroll Reveal ──
      var observer;
      function observeReveal(){
        if(observer) observer.disconnect();
        observer = new IntersectionObserver(function(entries){
          entries.forEach(function(e){
            if(e.isIntersecting){ e.target.classList.add('visible'); observer.unobserve(e.target); }
          });
        }, { threshold:0.15 });
        document.querySelectorAll('.reveal, .reveal-left, .stagger').forEach(function(el){ observer.observe(el); });
      }

      // ── Nav scroll effect ──
      function onScroll(){
        var bar = document.querySelector('.top-bar');
        if(!bar) return;
        bar.classList.toggle('scrolled', window.scrollY > 20);
      }
      window.addEventListener('scroll', onScroll, {passive:true});
      onScroll();

      // ── Init ──
      startParticles();
      applyLang();
      observeReveal();

      document.addEventListener('astro:after-swap', function(){
        startParticles();
        applyLang();
        onScroll();
        observeReveal();
      });
    </script>
  </body>
</html>
